---
import BaseLayout from '../layouts/BaseLayout.astro';
import Figure from '../components/Figure.astro';
import {
  exhibitKey,
  getAllReports,
  getChapterSections,
  getTableRows,
  getTopRisks,
  humanize,
  indexExhibits,
  sentence,
} from '../lib/reports';

export function getStaticPaths() {
  return getAllReports().map(({ summary, report }) => ({
    params: { slug: summary.slug },
    props: { summary, report },
  }));
}

const { summary, report } = Astro.props;
const topRisks: any[] = getTopRisks(report, 8);
const chapters: any[] = Array.isArray(report.chapters) ? report.chapters : [];
const tables: any[] = Array.isArray(report.tables) ? report.tables : [];
const figures: any[] = Array.isArray(report.figures) ? report.figures : [];
const sources: any[] = Array.isArray(report.sources) ? report.sources : [];
const evidenceClaims: any[] = Array.isArray(report.evidence_claims) ? report.evidence_claims : [];
const gaps: any[] = Array.isArray(report.diligence_gaps) ? report.diligence_gaps : [];
const requests: any[] = Array.isArray(report.follow_up_requests) ? report.follow_up_requests : [];
const meta = report.report_metadata ?? {};
const executive = report.executive_summary ?? {};
const evidenceClaimById = new Map(evidenceClaims.map((claim) => [String(claim.evidence_claim_id), claim]));
const exhibits = indexExhibits(report);
const tableIndex = new Map(tables.map((table) => [String(table.table_id ?? ''), table]));
const figureIndex = new Map(figures.map((figure) => [String(figure.figure_id ?? ''), figure]));
let figureCounter = 0;
const nextFigureIndex = () => figureCounter++;

function list(value: unknown, limit?: number): any[] {
  const arr = Array.isArray(value) ? value : [];
  return typeof limit === 'number' ? arr.slice(0, limit) : arr;
}

function text(value: unknown, fallback = '—'): string {
  const result = String(value ?? '').trim();
  return result.length ? result : fallback;
}

function sectionId(section: any) {
  return String(section?.section_id ?? '').replace(/[^a-zA-Z0-9_-]/g, '-');
}

function refIds(value: unknown): string[] {
  return Array.isArray(value) ? value.map(String).filter(Boolean) : [];
}

function evidenceRefs(value: unknown) {
  return refIds(value).map((id) => {
    const claim = evidenceClaimById.get(id);
    return {
      id,
      title: text(claim?.evidence_summary ?? claim?.claim ?? id, id),
      sourceIds: refIds(claim?.source_ids).slice(0, 4),
    };
  });
}

function decisionClass(value: string) {
  return `decision-${String(value ?? 'unknown').replace(/[^a-z0-9-]/gi, '-').toLowerCase()}`;
}

function semanticClass(prefix: string, value: unknown) {
  return `${prefix}-${String(value ?? 'unknown').replace(/[^a-z0-9-]/gi, '-').toLowerCase()}`;
}

const profileRows = [
  ['Website', meta.website],
  ['Sector', summary.sector],
  ['Geography', summary.geography],
  ['Stage', summary.stage],
  ['Known aliases', list(meta.known_aliases).join(', ')],
  ['Report version', meta.report_version],
  ['Timezone', meta.time_zone],
].filter(([, value]) => value !== undefined && value !== null && value !== '');

const strengths = list(executive.strongest_verified_claims, 5).map((item) => text(item?.summary ?? item));
const riskBullets = list(executive.biggest_risks, 5).map((item) => text(item?.summary ?? item));
const gapBullets = list(executive.key_evidence_gaps, 6).map((item) => text(item));
const nextSteps = list(executive.recommended_next_steps, 6).map((item) => text(item));
const fallbackStrengths = [summary.assessment].filter(Boolean);
---
<BaseLayout title={`${summary.company} — Startup Diligence`} description={summary.thesis || summary.assessment}>
  <section class="report-shell sr-container">
    <div class="print-watermark" aria-hidden="true">
      <span>
        <span class="wm-line wm-line-primary">AI-generated</span>
        <span class="wm-line wm-line-secondary">verify independently</span>
        <span class="wm-line wm-line-tertiary">startupv0.genisisiq.com</span>
      </span>
    </div>
    <header class="report-cover">
      <div class="report-cover-main">
        <div class="cover-eyebrow">
          <span class="cover-eyebrow-tag">Diligence report</span>
          <span class="cover-eyebrow-meta">{summary.sector}</span>
          <span class="cover-eyebrow-meta">{summary.stage}</span>
        </div>
        <h1>{summary.company}</h1>
        <p class="report-subtitle">{summary.title}</p>
        <p class="report-headline">{summary.thesis || summary.assessment}</p>
      </div>
      <aside class={`decision-card ${decisionClass(summary.recommendation)} ${semanticClass('risk', summary.risk)}`}>
        <div class="decision-headline">
          <span class="decision-eyebrow">Recommendation</span>
          <strong class="decision-rec">{summary.recommendation}</strong>
        </div>
        <div class="decision-score">
          <span class="decision-score-value">{summary.rating}</span>
          <span class="decision-score-label">Score / 10</span>
        </div>
        <dl class="decision-grid">
          <div><dt>Confidence</dt><dd>{topRisks[0]?.likelihood ? humanize(topRisks[0].likelihood) : 'Medium'}</dd></div>
          <div><dt>Risk rating</dt><dd><span class={`semantic-pill ${semanticClass('risk', summary.risk)}`}>{humanize(summary.risk)}</span></dd></div>
          <div><dt>Research date</dt><dd>{summary.researchDate}</dd></div>
          <div><dt>Sources</dt><dd>{summary.sourceCount} sources</dd></div>
        </dl>
        <div class="decision-actions">
          <button type="button" class="evidence-toggle" aria-pressed="false" data-show-label="Show refs" data-hide-label="Hide refs">Show refs</button>
          <button type="button" class="print-pdf" data-print-pdf title="Use the browser print dialog to save as PDF">Download PDF</button>
        </div>
      </aside>
    </header>

    <section class="report-section startup-intro">
      <h2>Company profile</h2>
      <p class="intro-heading"><strong>{summary.title}</strong></p>
      <p>{sentence(summary.assessment)}</p>
      <dl class="intro-grid">
        {profileRows.map(([label, value]) => (
          <div>
            <dt>{label}</dt>
            <dd>{label === 'Website' && typeof value === 'string' ? <a href={value}>{value.replace(/^https?:\/\//, '').replace(/\/$/, '')}</a> : text(value)}</dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="report-section executive-summary">
      <h2>Executive summary</h2>
      <div class="three-col">
        <article class="summary-card summary-strengths">
          <h2>Strengths</h2>
          <ul>{(strengths.length ? strengths : fallbackStrengths).map((item) => <li>{item}</li>)}</ul>
        </article>
        <article class="summary-card summary-risks">
          <h2>Risks</h2>
          <ul>{riskBullets.map((item) => <li>{item}</li>)}</ul>
        </article>
        <article class="summary-card summary-gaps">
          <h2>Gaps</h2>
          <ul>{gapBullets.map((item) => <li>{item}</li>)}</ul>
        </article>
      </div>
    </section>

    {nextSteps.length > 0 && (
      <section class="report-section next-steps">
        <h2>Recommended next steps</h2>
        <div class="summary-card summary-gaps">
          <ul>{nextSteps.map((item) => <li>{item}</li>)}</ul>
        </div>
      </section>
    )}

    {topRisks.length > 0 && (
      <section class="report-section risk-register">
        <h2>Risk register</h2>
        <div class="three-col risk-card-grid">
          {topRisks.map((risk) => (
            <article class={`summary-card summary-risks ${semanticClass('risk-card', risk.severity)}`}>
              <p class="risk-meta">
                <span class={`semantic-pill ${semanticClass('risk', risk.severity)}`}>{humanize(risk.severity)}</span>
                <span class={`semantic-pill ${semanticClass('confidence', risk.likelihood)}`}>{humanize(risk.likelihood)} likelihood</span>
              </p>
              <h2>{risk.risk_id}: {risk.risk_title}</h2>
              <p>{risk.description}</p>
              {risk.mitigation_or_diligence_request && <p><strong>Diligence request:</strong> {risk.mitigation_or_diligence_request}</p>}
            </article>
          ))}
        </div>
      </section>
    )}

    {chapters.map((chapter, chapterIndex) => (
      <article class="report-chapter" id={`chapter-${chapter.chapter_id}`}>
        <header class="chapter-header">
          <span class="chapter-eyebrow">Chapter {String(chapterIndex + 1).padStart(2, '0')}</span>
          <h2><span class="chapter-number">{String(chapterIndex + 1).padStart(2, '0')}</span><span class="chapter-title">{chapter.title}</span></h2>
          <p class="chapter-summary">{sentence(chapter.chapter_summary)}</p>
          {evidenceRefs(chapter.evidence_claim_ids).length > 0 && (
            <div class="ref-list chapter-ref-list" aria-label="Chapter evidence references">
              {evidenceRefs(chapter.evidence_claim_ids).map((ref) => (
                <a class="ref-chip" href={`#${ref.id}`} title={ref.title}>{ref.id}</a>
              ))}
            </div>
          )}
        </header>
        {getChapterSections(chapter).map((section) => (
          <section class="chapter-section" id={sectionId(section)}>
            <h3>{section.section_id} {section.title}</h3>
            <p class="section-status">
              <span class={`status-pill ${semanticClass('status', section.verification_status)}`}>{humanize(section.verification_status)}</span>
              <span class={`status-pill ${semanticClass('confidence', section.confidence)}`}>confidence: {humanize(section.confidence)}</span>
            </p>
            <p>{sentence(section.summary)}</p>
            {evidenceRefs(section.evidence_claim_ids).length > 0 && (
              <div class="ref-list section-ref-list" aria-label="Section evidence references">
                {evidenceRefs(section.evidence_claim_ids).map((ref) => (
                  <a class="ref-chip" href={`#${ref.id}`} title={ref.title}>{ref.id}</a>
                ))}
              </div>
            )}
            {list(section.key_findings).length > 0 && (
              <aside class="report-callout callout-insight">
                <span class="callout-eyebrow">key findings</span>
                <ul>
                  {list(section.key_findings, 6).map((finding) => (
                    <li>
                      <span>{text(finding?.finding ?? finding)}</span>
                      {evidenceRefs(finding?.evidence_claim_ids).length > 0 && (
                        <span class="ref-list finding-ref-list" aria-label="Finding evidence references">
                          {evidenceRefs(finding?.evidence_claim_ids).map((ref) => (
                            <a class="ref-chip" href={`#${ref.id}`} title={ref.title}>{ref.id}</a>
                          ))}
                        </span>
                      )}
                    </li>
                  ))}
                </ul>
              </aside>
            )}
            <div class="section-lists">
              {list(section.evidence_gaps).length > 0 && <div><h4>Evidence gaps</h4><ul>{list(section.evidence_gaps, 5).map((gap) => <li>{text(gap)}</li>)}</ul></div>}
              {list(section.hidden_risks).length > 0 && <div><h4>Hidden risks</h4><ul>{list(section.hidden_risks, 5).map((risk) => <li>{text(risk)}</li>)}</ul></div>}
              {list(section.follow_up_questions).length > 0 && <div><h4>Follow-up questions</h4><ul>{list(section.follow_up_questions, 5).map((question) => <li>{text(question)}</li>)}</ul></div>}
            </div>
            {(() => {
              const sectionKey = exhibitKey(chapter.chapter_id, section.section_id);
              const nativeTables = exhibits.tablesBySection.get(sectionKey) ?? [];
              const nativeFigures = exhibits.figuresBySection.get(sectionKey) ?? [];
              const refdTables = refIds(section.table_ids)
                .map((id) => tableIndex.get(id))
                .filter((t): t is any => Boolean(t));
              const refdFigures = refIds(section.figure_ids)
                .map((id) => figureIndex.get(id))
                .filter((f): f is any => Boolean(f));
              // Render each exhibit at most once per page. First section that
              // either owns the exhibit (native chapter+section) OR explicitly
              // references it via {table,figure}_ids wins; later mentions are
              // suppressed to avoid duplicate DOM ids and double-rendering.
              const allTables = [];
              const seenTables = new Set();
              for (const table of [...nativeTables, ...refdTables]) {
                const id = String(table.table_id);
                if (exhibits.placedTableIds.has(id) || seenTables.has(id)) continue;
                seenTables.add(id);
                allTables.push(table);
              }
              const allFigures = [];
              const seenFigures = new Set();
              for (const figure of [...nativeFigures, ...refdFigures]) {
                const id = String(figure.figure_id);
                if (exhibits.placedFigureIds.has(id) || seenFigures.has(id)) continue;
                seenFigures.add(id);
                allFigures.push(figure);
              }
              for (const table of allTables) exhibits.placedTableIds.add(String(table.table_id));
              for (const figure of allFigures) exhibits.placedFigureIds.add(String(figure.figure_id));
              return (allTables.length > 0 || allFigures.length > 0) ? (
                <div class="section-exhibits">
                  {allTables.map((table) => (
                    <div class="table-frame inline-exhibit" id={table.table_id}>
                      <table>
                        <caption>{table.title}</caption>
                        <thead>
                          <tr>{list(table.columns).map((column) => <th>{humanize(column.name)}</th>)}</tr>
                        </thead>
                        <tbody>
                          {getTableRows(table).map((row) => (
                            <tr>{list(table.columns).map((column) => <td>{text(row.values?.[column.name])}</td>)}</tr>
                          ))}
                        </tbody>
                      </table>
                      {table.notes && <p class="table-note">{table.notes}</p>}
                    </div>
                  ))}
                  {allFigures.map((figure) => (
                    <Figure figure={figure} index={nextFigureIndex()} />
                  ))}
                </div>
              ) : null;
            })()}
          </section>
        ))}
        {(() => {
          const chapterTables = (exhibits.tablesByChapter.get(String(chapter.chapter_id)) ?? []).filter((t) => !exhibits.placedTableIds.has(String(t.table_id)));
          const chapterFigures = (exhibits.figuresByChapter.get(String(chapter.chapter_id)) ?? []).filter((f) => !exhibits.placedFigureIds.has(String(f.figure_id)));
          for (const table of chapterTables) exhibits.placedTableIds.add(String(table.table_id));
          for (const figure of chapterFigures) exhibits.placedFigureIds.add(String(figure.figure_id));
          return (chapterTables.length > 0 || chapterFigures.length > 0) ? (
            <section class="chapter-section chapter-exhibits">
              <h3>Chapter exhibits</h3>
              <div class="section-exhibits">
                {chapterTables.map((table) => (
                  <div class="table-frame inline-exhibit" id={table.table_id}>
                    <table>
                      <caption>{table.title}</caption>
                      <thead>
                        <tr>{list(table.columns).map((column) => <th>{humanize(column.name)}</th>)}</tr>
                      </thead>
                      <tbody>
                        {getTableRows(table).map((row) => (
                          <tr>{list(table.columns).map((column) => <td>{text(row.values?.[column.name])}</td>)}</tr>
                        ))}
                      </tbody>
                    </table>
                    {table.notes && <p class="table-note">{table.notes}</p>}
                  </div>
                ))}
                {chapterFigures.map((figure) => (
                  <Figure figure={figure} index={nextFigureIndex()} />
                ))}
              </div>
            </section>
          ) : null;
        })()}
      </article>
    ))}

    {(() => {
      const orphanTables = tables.filter((table) => !exhibits.placedTableIds.has(String(table.table_id)));
      const orphanFigures = figures.filter((figure) => !exhibits.placedFigureIds.has(String(figure.figure_id)));
      return (orphanTables.length > 0 || orphanFigures.length > 0) ? (
        <section class="report-section evidence-index">
          <h2>Unfiled exhibits</h2>
          {orphanTables.map((table) => (
            <div class="table-frame" id={table.table_id}>
              <table>
                <caption>{table.title}</caption>
                <thead>
                  <tr>{list(table.columns).map((column) => <th>{humanize(column.name)}</th>)}</tr>
                </thead>
                <tbody>
                  {getTableRows(table).map((row) => (
                    <tr>{list(table.columns).map((column) => <td>{text(row.values?.[column.name])}</td>)}</tr>
                  ))}
                </tbody>
              </table>
              {table.notes && <p class="table-note">{table.notes}</p>}
            </div>
          ))}
          {orphanFigures.map((figure) => (
            <Figure figure={figure} index={nextFigureIndex()} />
          ))}
        </section>
      ) : null;
    })()}

    {(evidenceClaims.length > 0 || sources.length > 0 || gaps.length > 0 || requests.length > 0) && (
      <section class="report-section evidence-index">
        <h2>Evidence</h2>
        {evidenceClaims.length > 0 && (
          <div class="table-frame evidence-claims-table">
            <table>
              <caption>Evidence claims</caption>
              <thead><tr><th>ID</th><th>Claim</th><th>Status</th><th>Sources</th></tr></thead>
              <tbody>
                {evidenceClaims.map((claim) => (
                  <tr id={claim.evidence_claim_id}>
                    <td><a class="evidence-id" href={`#${claim.evidence_claim_id}`}>{claim.evidence_claim_id}</a></td>
                    <td>{text(claim.claim ?? claim.evidence_summary)}</td>
                    <td class="evidence-status-cell">
                      <span class={`status-pill ${semanticClass('status', claim.verification_status)}`}>{humanize(claim.verification_status)}</span>
                      <span class={`status-pill ${semanticClass('confidence', claim.confidence)}`}>{humanize(claim.confidence)}</span>
                    </td>
                    <td>
                      <span class="table-ref-list">
                        {refIds(claim.source_ids).map((sourceId) => (
                          <a class="ref-chip ref-chip--source" href={`#${sourceId}`}>{sourceId}</a>
                        ))}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
        {sources.length > 0 && (
          <div class="table-frame">
            <table>
              <caption>Sources</caption>
              <thead><tr><th>ID</th><th>Publisher</th><th>Title</th><th>Accessed</th></tr></thead>
              <tbody>
                {sources.map((source) => (
                  <tr id={source.source_id}>
                    <td><a class="evidence-id" href={`#${source.source_id}`}>{source.source_id}</a></td>
                    <td>{text(source.publisher || source.source_type)}</td>
                    <td>{source.url ? <a href={source.url}>{source.title}</a> : text(source.title)}</td>
                    <td>{text(source.accessed_date)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </section>
    )}

    <section class="report-section report-disclaimer" aria-labelledby="report-disclaimer-heading">
      <h2 id="report-disclaimer-heading">Disclaimer</h2>
      <p>
        This report is a public-evidence diligence snapshot, not investment advice.
        Important financial, legal, technical, and contractual facts remain non-public
        and should be verified directly with management and primary documents before
        any investment decision.
      </p>
    </section>

    <div class="floating-actions" aria-label="Report shortcuts">
      {chapters.length > 0 && (
        <div class="chapter-jump" data-chapter-jump>
          <button type="button" class="chapter-jump__toggle" data-chapter-toggle aria-label="Select chapter" title="Select chapter" aria-expanded="false" aria-controls="chapter-jump-menu">
            <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true" focusable="false">
              <path d="M6.75 4.75h7.25M6.75 9h7.25M6.75 13.25h7.25" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
              <path d="M3.75 4.75h.01M3.75 9h.01M3.75 13.25h.01" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
            </svg>
          </button>
          <nav class="chapter-jump__menu" id="chapter-jump-menu" data-chapter-menu aria-label="Select chapter" hidden>
            <ol>
              {chapters.map((chapter, index) => (
                <li class="chapter-jump__item" data-chapter-target={`chapter-${chapter.chapter_id}`}>
                  <a href={`#chapter-${chapter.chapter_id}`} data-chapter-link>
                    <span class="chapter-jump__number">{String(index + 1).padStart(2, '0')}</span>
                    <span class="chapter-jump__title">{chapter.title}</span>
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </div>
      )}
      <button type="button" class="back-to-top" data-back-to-top aria-label="Back to top" title="Back to top">
        <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true" focusable="false">
          <path d="M9 3.5 L9 14.5 M9 3.5 L4 8.5 M9 3.5 L14 8.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
    </div>
  </section>

  <script>
    const reportShell = document.querySelector<HTMLElement>('.report-shell');
    const printButton = document.querySelector<HTMLButtonElement>('[data-print-pdf]');
    if (printButton) {
      printButton.addEventListener('click', () => window.print());
    }

    const backToTop = document.querySelector<HTMLButtonElement>('[data-back-to-top]');
    if (backToTop) {
      backToTop.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    }

    const evidenceToggle = document.querySelector<HTMLButtonElement>('.evidence-toggle');
    if (reportShell && evidenceToggle) {
      const showLabel = evidenceToggle.dataset.showLabel || 'Show refs';
      const hideLabel = evidenceToggle.dataset.hideLabel || 'Hide refs';
      const setRefsVisible = (visible: boolean) => {
        reportShell.classList.toggle('refs-visible', visible);
        evidenceToggle.setAttribute('aria-pressed', String(visible));
        evidenceToggle.textContent = visible ? hideLabel : showLabel;
      };
      evidenceToggle.addEventListener('click', () => setRefsVisible(!reportShell.classList.contains('refs-visible')));
      setRefsVisible(false);
    }

    for (const frame of document.querySelectorAll<HTMLElement>('.table-frame')) {
      if (frame.dataset.responsive === 'ready') continue;
      const headerCells = Array.from(frame.querySelectorAll<HTMLTableCellElement>('thead th'));
      const labels = headerCells.map((th) => (th.textContent || '').trim());
      if (!labels.length) continue;
      frame.dataset.columns = String(labels.length);
      for (const row of frame.querySelectorAll('tbody tr')) {
        const cells = row.children;
        for (let i = 0; i < cells.length; i++) {
          const cell = cells[i];
          if (cell.tagName === 'TD' && labels[i]) cell.setAttribute('data-label', labels[i]);
        }
      }
      frame.dataset.responsive = 'ready';
    }

    const chapterJump = document.querySelector<HTMLElement>('[data-chapter-jump]');
    if (chapterJump) {
      type ChapterTarget = { item: HTMLElement; el: HTMLElement };
      const toggle = chapterJump.querySelector<HTMLButtonElement>('[data-chapter-toggle]');
      const menu = chapterJump.querySelector<HTMLElement>('[data-chapter-menu]');
      const items = Array.from(chapterJump.querySelectorAll<HTMLElement>('[data-chapter-target]'));
      const links = Array.from(chapterJump.querySelectorAll<HTMLAnchorElement>('[data-chapter-link]'));
      const setChapterMenuOpen = (open: boolean) => {
        if (!toggle || !menu) return;
        menu.hidden = !open;
        toggle.setAttribute('aria-expanded', String(open));
        chapterJump.classList.toggle('is-open', open);
      };
      toggle?.addEventListener('click', () => setChapterMenuOpen(menu ? menu.hidden : true));
      links.forEach((link) => link.addEventListener('click', () => setChapterMenuOpen(false)));
      document.addEventListener('click', (event) => {
        if (!chapterJump.contains(event.target as Node)) setChapterMenuOpen(false);
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') setChapterMenuOpen(false);
      });

      const targets = items
        .map((item) => {
          const id = item.dataset.chapterTarget;
          const el = id ? document.getElementById(id) : null;
          return el ? { item, el } : null;
        })
        .filter((target): target is ChapterTarget => Boolean(target));
      if (targets.length && 'IntersectionObserver' in window) {
        const visible = new Map<Element, number>();
        const setActive = (activeItem: HTMLElement) => items.forEach((item) => item.classList.toggle('is-active', item === activeItem));
        const observer = new IntersectionObserver((entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) visible.set(entry.target, entry.intersectionRatio);
            else visible.delete(entry.target);
          }
          let bestEl: Element | null = null;
          let bestRatio = 0;
          for (const [el, ratio] of visible) {
            if (ratio > bestRatio) { bestRatio = ratio; bestEl = el; }
          }
          if (bestEl) {
            const match = targets.find((target) => target.el === bestEl);
            if (match) setActive(match.item);
          }
        }, { rootMargin: '-30% 0px -55% 0px', threshold: [0, 0.25, 0.5, 0.75, 1] });
        targets.forEach(({ el }) => observer.observe(el));
      }
