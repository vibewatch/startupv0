---
import type { ReportSummary } from '../lib/reports';

interface Props {
  report: ReportSummary;
}

const { report } = Astro.props;

function toneClass(prefix: string, value: unknown) {
  return `${prefix}-${String(value ?? 'unknown').replace(/[^a-z0-9-]/gi, '-').toLowerCase()}`;
}

const description = report.thesis || report.assessment;
const hasRating = Boolean(report.rating) && report.rating !== '—';
const hasSources = Number(report.sourceCount) > 0;
---
<a class={`report-card ${toneClass('risk', report.risk)}`} href={`/${report.slug}/`}>
  {report.sector && <p class="card-sector">{report.sector}</p>}
  {report.stage && <p class="card-stage">{report.stage}</p>}
  <h3 class="card-title">{report.company}</h3>
  {description && <p class="card-thesis">{description}</p>}
  {(report.recommendation || report.risk) && (
    <div class="card-tags" aria-label="Report tags">
      {report.recommendation && <span class="card-pill">{report.recommendation}</span>}
      {report.risk && <span class="card-pill">Risk: {report.risk}</span>}
    </div>
  )}
  {(hasRating || hasSources) && (
    <footer class="card-footer">
      {hasRating && (
        <span class="card-rating" aria-label={`Rating ${report.rating}`}>{report.rating}</span>
      )}
      <p class="card-meta">
        {hasRating && <span>Rating</span>}
        {hasRating && hasSources && <span class="card-meta__dot" aria-hidden="true">·</span>}
        {hasSources && <span>{report.sourceCount} sources</span>}
      </p>
    </footer>
  )}
</a>

<style>
  .report-card {
    --tone: var(--charcoal-83);
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 100%;
    border: 1px solid var(--border-cream);
    border-radius: var(--radius-card);
    background: var(--cream-base);
    padding: var(--space-5);
    color: var(--charcoal);
    text-decoration: none;
    transition: border-color 140ms ease, background-color 140ms ease;
  }
  .report-card:hover,
  .report-card:focus-visible {
    border-color: var(--charcoal-40);
    background: var(--charcoal-03);
  }
  .report-card:hover .card-title,
  .report-card:focus-visible .card-title {
    opacity: 0.85;
  }

  .report-card.risk-critical,
  .report-card.risk-high { --tone: var(--semantic-danger); }
  .report-card.risk-medium { --tone: var(--semantic-warning); }
  .report-card.risk-low { --tone: var(--semantic-success); }
  .report-card.risk-monitor,
  .report-card.risk-watch { --tone: var(--semantic-info); }

  .card-sector,
  .card-stage {
    margin: 0 0 var(--space-2);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .card-sector { color: var(--tone); }
  .card-stage { color: var(--muted-gray); }

  .card-title {
    margin: var(--space-3) 0 var(--space-3);
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: var(--tracking-subhead);
    color: var(--charcoal);
    overflow-wrap: anywhere;
    transition: opacity 120ms ease;
  }

  .card-thesis {
    margin: 0 0 var(--space-5);
    color: var(--muted-gray);
    font-family: var(--font-sans);
    font-size: var(--fs-base);
    font-weight: 400;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: 0 0 var(--space-5);
  }
  .card-pill {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--charcoal-40);
    border-radius: var(--radius-control);
    padding: 6px 10px;
    background: transparent;
    color: var(--charcoal);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .card-footer {
    margin-top: auto;
    padding-top: var(--space-4);
    border-top: 1px solid var(--border-cream);
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .card-rating {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    padding: var(--space-2) var(--space-3);
    background: var(--tone);
    color: var(--cream-highlight);
    border-radius: var(--radius-control);
    font-family: var(--font-display);
    font-size: var(--fs-md);
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.02em;
    font-feature-settings: 'tnum' on, 'lnum' on;
    font-variant-numeric: tabular-nums lining-nums;
  }
  .card-meta {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    color: var(--muted-gray);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .card-meta__dot { color: var(--charcoal-40); }
</style>
